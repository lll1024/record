":"object"}},{"name":"get_trade_dates","description":"\n        获取指定范围内的交易日信息\n\n        参数:\n            start_date: 可选的开始日期，格式为'YYYY-MM-DD'。如果为None，默认为2015-01-01\n            end_date: 可选的结束日期，格式为'YYYY-MM-DD'。如果为None，默认为当前日期\n\n        返回:\n            指示范围内每个日期是否为交易日（1）或非交易日（0）的Markdown表格\n        ","inputSchema":{"properties":{"start_date":{"anyOf":[{"type":"string"},{"type":"null"}],"default":null,"title":"Start Date"},"end_date":{"anyOf":[{"type":"string"},{"type":"null"}],"default":null,"title":"End Date"}},"title":"get_trade_datesArguments","type":"object"},"outputSchema":{"properties":{"result":{"title":"Result","type":"string"}},"required":["result"],"title":"get_trade_datesOutput","type":"object"}},{"name":"get_all_stock","description":"\n        获取指定日期的所有股票（A股和指数）列表及其交易状态\n\n        参数:\n            date: 可选的日期，格式为'YYYY-MM-DD'。如果为None，则使用当前日期\n\n        返回:\n            列出股票代码、名称及其交易状态（1=交易中，0=停牌）的Markdown表格\n        ","inputSchema":{"properties":{"date":{"anyOf":[{"type":"string"},{"type":"null"}],"default":null,"title":"Date"}},"title":"get_all_stockArguments","type":"object"},"outputSchema":{"properties":{"result":{"title":"Result","type":"string"}},"required":["result"],"title":"get_all_stockOutput","type":"object"}},{"name":"get_deposit_rate_data","description":"\n        获取指定日期范围内的基准存款利率数据（活期、定期）\n\n        参数:\n            start_date: 可选的开始日期，格式为'YYYY-MM-DD'\n            end_date: 可选的结束日期，格式为'YYYY-MM-DD'\n\n        返回:\n            包含存款利率数据的Markdown表格或错误消息\n        ","inputSchema":{"properties":{"start_date":{"anyOf":[{"type":"string"},{"type":"null"}],"default":null,"title":"Start Date"},"end_date":{"anyOf":[{"type":"string"},{"type":"null"}],"default":null,"title":"End Date"}},"title":"get_deposit_rate_dataArguments","type":"object"},"outputSchema":{"properties":{"result":{"title":"Result","type":"string"}},"required":["result"],"title":"get_deposit_rate_dataOutput","type":"object"}},{"name":"get_loan_rate_data","description":"\n        获取指定日期范围