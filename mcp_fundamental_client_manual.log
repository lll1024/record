内的基准贷款利率数据（贷款利率）\n\n        参数:\n            start_date: 可选的开始日期，格式为'YYYY-MM-DD'\n            end_date: 可选的结束日期，格式为'YYYY-MM-DD'\n\n        返回:\n            包含贷款利率数据的Markdown表格或错误消息\n        ","inputSchema":{"properties":{"start_date":{"anyOf":[{"type":"string"},{"type":"null"}],"default":null,"title":"Start Date"},"end_date":{"anyOf":[{"type":"string"},{"type":"null"}],"default":null,"title":"End Date"}},"title":"get_loan_rate_dataArguments","type":"object"},"outputSchema":{"properties":{"result":{"title":"Result","type":"string"}},"required":["result"],"title":"get_loan_rate_dataOutput","type":"object"}},{"name":"get_required_reserve_ratio_data","description":"\n        获取指定日期范围内的存款准备金率数据\n\n        参数:\n            start_date: 可选的开始日期，格式为'YYYY-MM-DD'\n            end_date: 可选的结束日期，格式为'YYYY-MM-DD'\n            year_type: 可选的年份类型，用于日期过滤。'0'表示公告日期（默认），'1'表示生效日期\n\n        返回:\n            包含存款准备金率数据的Markdown表格或错误消息\n        ","inputSchema":{"properties":{"start_date":{"anyOf":[{"type":"string"},{"type":"null"}],"default":null,"title":"Start Date"},"end_date":{"anyOf":[{"type":"string"},{"type":"null"}],"default":null,"title":"End Date"},"year_type":{"default":"0","title":"Year Type","type":"string"}},"title":"get_required_reserve_ratio_dataArguments","type":"object"},"outputSchema":{"properties":{"result":{"title":"Result","type":"string"}},"required":["result"],"title":"get_required_reserve_ratio_dataOutput","type":"object"}},{"name":"get_money_supply_data_month","description":"\n        获取指定日期范围内的月度货币供应量数据（M0、M1、M2）\n\n        参数:\n            start_date: 可选的开始日期，格式为'YYYY-MM'\n            end_date: 可选的结束日期，格式为'YYYY-MM'\n\n        返回:\n            包含月度货币供应量数据的Markdown表格或错误消息\n        ","inputSchema":{"properties":{"start_date":{"anyOf":[{"type":"string"},{"type":"null"}],"default":null,"title":"Start Date"},"end_date":{"anyOf":[{"type":"string"},{"type":"null"}],"default":null,"title":"End Date"}},"title":"get_money_supply_data_monthArguments","type":"object"},"outp