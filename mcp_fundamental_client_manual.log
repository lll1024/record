ype":"object"}},{"name":"get_stock_analysis","description":"\n        提供基于数据的股票分析报告，而非投资建议。\n\n        参数:\n            code: 股票代码，如'sh.600000'\n            analysis_type: 分析类型，可选'fundamental'(基本面)、'technical'(技术面)或'comprehensive'(综合)\n\n        返回:\n            数据驱动的分析报告，包含关键财务指标、历史表现和同行业比较\n        ","inputSchema":{"properties":{"code":{"title":"Code","type":"string"},"analysis_type":{"default":"fundamental","title":"Analysis Type","type":"string"}},"required":["code"],"title":"get_stock_analysisArguments","type":"object"},"outputSchema":{"properties":{"result":{"title":"Result","type":"string"}},"required":["result"],"title":"get_stock_analysisOutput","type":"object"}},{"name":"crawl_news","description":"\n        爬取相关新闻\n        \n        使用百度搜索爬取与查询词相关的新闻文章，并返回格式化的结果。\n        \n        Args:\n            query: 搜索查询词，如\"嘉友国际\"、\"人工智能投资\"等\n            top_k: 返回的新闻数量，默认为10条\n            \n        Returns:\n            格式化的新闻结果字符串，包含标题、内容摘要、链接等信息\n            \n        Example:\n            >>> crawl_news(\"嘉友国际\", 5)\n            \"找到以下相关新闻：\n            \n            1. 嘉友国际发布2024年第一季度财报\n               来源: 百度搜索\n               内容: 嘉友国际今日发布2024年第一季度财报，营收同比增长15%...\n               链接: https://example.com/news/123\n            \"\n        ","inputSchema":{"properties":{"query":{"title":"Query","type":"string"},"top_k":{"default":10,"title":"Top K","type":"integer"}},"required":["query"],"title":"crawl_newsArguments","type":"object"},"outputSchema":{"properties":{"result":{"title":"Result","type":"string"}},"required":["result"],"title":"crawl_newsOutput","type":"object"}}]}}
